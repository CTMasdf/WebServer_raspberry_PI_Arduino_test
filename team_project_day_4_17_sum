void Serialled(){
  if (Serial.available()) {
    inputString = Serial.readStringUntil('\n');
    inputString.trim();  // 공백 제거

    // 모든 LED 끄기
    for (int i = 0; i < 4; i++) {
      digitalWrite(ledPins[i], LOW);
    }

    // 조건에 따라 하나만 켜기
    if (inputString == "GENERAL") {
      digitalWrite(ledPins[0], HIGH);
    }
    else if (inputString == "PLASTIC") {
      digitalWrite(ledPins[1], HIGH);
    }
    else if (inputString == "GLASS") {
      digitalWrite(ledPins[2], HIGH);
    }
    else if (inputString == "CAN") {
      digitalWrite(ledPins[3], HIGH);
    }
  }
}

ISR(TIMER2_OVF_vect) {
  // 1ms 주기를 위한 타이머 초깃값 설정
  // 계산식: 256 - (16MHz / 64 / 1000Hz) = 256 - 250 = 6
  // 또는 분주비에 따라 131 등을 사용 (하단 설명 참조)
  TCNT2 = 6; // 10us
  time++;
  // 1ms씩 증가하므로 1000번 카운트하면 1초입니다.
  if (time >= 3000) {
    
    time = 0;
  }
  
}

void setup() {

  // 초기 설정
  // PUSH 센서
  pinMode(PUSH_SEN_1, INPUT);
  pinMode(PUSH_SEN_2, INPUT);

  // X 이동 IR 센서
  pinMode(X_MOVE_IR_1, INPUT);
  pinMode(X_MOVE_IR_2, INPUT);
  //pinMode(X_MOVE_IR_3, INPUT);
 // pinMode(X_MOVE_IR_4, INPUT);

  // 모터 쉬프트 레지스터(출력 모드로 설정)
  pinMode(MOTOR_SHIFT_DATA, OUTPUT);
  pinMode(MOTOR_SHIFT_CLK, OUTPUT);
  pinMode(MOTOR_SHIFT_STR, OUTPUT);

  // 서보 모터 핀
  pinMode(SERVO_MO_IN1, OUTPUT);
  pinMode(SERVO_MO_IN2, OUTPUT);
  //pinMode(SERVO_MO_IN3, OUTPUT);

  // 기타 센서
  pinMode(IRON_SEN1, INPUT);
  pinMode(Trash_IR_IN, INPUT);

  // 초음파 센서 TRIG
  pinMode(TRASH_CHO_1_TRIG, OUTPUT);
  pinMode(TRASH_CHO_2_TRIG, OUTPUT);
  pinMode(TRASH_CHO_3_TRIG, OUTPUT);
  pinMode(TRASH_CHO_4_TRIG, OUTPUT);

  // 초음파 센서 ECHO
  pinMode(TRASH_CHO_1_ECHO, INPUT);
  pinMode(TRASH_CHO_2_ECHO, INPUT);
  pinMode(TRASH_CHO_3_ECHO, INPUT);
  pinMode(TRASH_CHO_4_ECHO, INPUT);


  // 투입구서보모터 초기 각도 설정 및 시작
  myServo_1.attach(SERVO_MO_IN1); 
  myServo_1.write(0);         

  // 쓰레받이 서보모터 초기 각도 설정 및 시작
  myServo_2.attach(SERVO_MO_IN2); 
  myServo_2.write(0);         

  // 쓰레받이 서보모터 초기 각도 설정 및 시작
//  myServo_3.attach(SERVO_MO_IN3); 
//  myServo_3.write(0);         

  // 시리얼 통신
  Serial.begin(9600);

   // Timer2 설정 (1ms 주기, 프리스케일러 128)
  TCCR2A = 0x00;
  TCCR2B = 0x05;    // 프리스케일러 128
  TCNT2 = 0xE7;     // 1ms 정도 간격으로 인터럽트 발생
  TIMSK2 = 0x01;    // 오버플로우 인터럽트 허용
  sei();            // 전역 인터럽트 허용 

  // 3. 아두이노가 켜질 때 액추에이터가 제멋대로 움직이는 것을 막기 위해 '모두 정지(0)' 상태로 초기화합니다.
  registerState = 0; 
  updateShiftRegister(); // 이 함수를 호출해야 4094 칩으로 0(정지) 신호가 확정되어 들어갑니다.
  
}

void loop() {
  // 여기에 센서 입력값 받아오기.
  buttonControl();  // 압력센서 함수
  Trash_IR();       // 쓰레기 투입 감지 적외선 센서
  X_MOVE_IR();      // X축 이동 감지 ir 센서
  IRON_SEN();       // 금속 감지 센서
  CHO_SEN_1();      // 일반쓰레기 용량 감지 초음파 센서
  CHO_SEN_2();      // 플라스틱 쓰레기 용량 감지 초음파 센서
  CHO_SEN_3();      // 캔 쓰레기 용량 감지 초음파 센서
  CHO_SEN_4();      // 유리 쓰레기 용량 감지 초음파 센서
  //Serialled();       // 시리얼 값에 따라 led핀을 출력
  
  // 쓰레기가 감지되었을 때(예: LOW 신호)만 액추에이터 작동
  if (trash_ir_val == LOW) { 
    //moveActuator(); // 액추에이터 작동
    servo_first(); // 쓰레기 들어오면 문 열기
  servo_seconde(); // 쓰레받이 작동
  }
    X_MOVE_IR_serial();
  CHO_SEN_1_serial();
    CHO_SEN_2_serial();
    CHO_SEN_3_serial();
    CHO_SEN_4_serial();
}
