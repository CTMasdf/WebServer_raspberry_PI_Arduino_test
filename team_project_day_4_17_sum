/******* 압력 센서 *******/
void buttonControl() {
  // 1. 아날로그 값 읽기 (전역변수에 저장)
  pressure_1_val = analogRead(PUSH_SEN_1);
  pressure_2_val = analogRead(PUSH_SEN_2);

  // 2. 아날로그 값을 전압(mV)으로 변환 (0~5000mV)
  // map(값, 저점, 고점, 변환저점, 변환고점)
  long pressure1_mv = map(pressure_1_val, 0, 1023, 0, 5000);
  long pressure2_mv = map(pressure_2_val, 0, 1023, 0, 5000);

  // 3. 간이 무게 변환 (테스트용 근사치 계산)
  // 전압이 높을수록 센서를 누르는 힘이 강하다는 뜻입니다.
  // 실제 센서의 데이터시트에 따라 보정이 필요할 수 있습니다.
  long weight1 = 0;
  long weight2 = 0;

  if (pressure1_mv > 0) weight1 = pressure1_mv * 2; // 임의의 가중치 2를 곱해 g 단위 생성
  if (pressure2_mv > 0) weight2 = pressure2_mv * 2;

  // 4. 시리얼 모니터 출력
  Serial.print(" | P1 무게: ");
  Serial.print(weight1);
  Serial.print(" g \n");
  
  Serial.print(" | P2 무게: ");
  Serial.print(weight2);
  Serial.println(" g");
}

/****** 모터, 엑추에이터 제어*******/
/*ic4094 함수 선언 | ic4094 function declaration*/
void ic4094(int data){
   int i;                        //for문 변수 i생성 | for statement create variable i
   for(i = 0; i < 8; i++){         //ic4094 핀이 8개 이기 때문에 0~7까지 반복 | There are 16 ic4094 pins, so repeat from 0 to 15.
      if(data&(0x80 >> i)){         //입력된 data값과 0x8000이 i값 만큼 오른쪽으로 쉬프트 했을 때 1이 되면 | If the input data value and 0x8000 become 1 when moving to the right by the i value,
      digitalWrite(MOTOR_SHIFT_DATA, HIGH);
      }
      else
      digitalWrite(MOTOR_SHIFT_DATA, LOW);
    digitalWrite(MOTOR_SHIFT_CLK, HIGH);
    delay(1);
      digitalWrite(MOTOR_SHIFT_CLK, LOW);
    //CLK_OFF
   }
   digitalWrite(MOTOR_SHIFT_STR, HIGH);
    delay(1);
   digitalWrite(MOTOR_SHIFT_STR, LOW);
    
}

// 시프트 레지스터 상태 업데이트 함수 (이게 꼭 있어야 합니다!)
void updateShiftRegister() {
  digitalWrite(MOTOR_SHIFT_STR, LOW);
  shiftOut(MOTOR_SHIFT_DATA, MOTOR_SHIFT_CLK, MSBFIRST, registerState);
  digitalWrite(MOTOR_SHIFT_STR, HIGH);
}

/******* 액추에이터 제어 함수 *******/
void moveActuator() {
  // 1. 전진 (나오기)
  Serial.println("Actuator: FORWARD START");
  bitSet(registerState, MOTOR_ACT1_BIT);   // Q1 = 1
  bitClear(registerState, MOTOR_ACT2_BIT); // Q2 = 0
  updateShiftRegister();
  delay(3000); // 완전히 나올 때까지 대기

  // 2. 중간 정지 (기계적 부하 방지)
  bitClear(registerState, MOTOR_ACT1_BIT);
  bitClear(registerState, MOTOR_ACT2_BIT);
  updateShiftRegister();
  Serial.println("Actuator: STOP");
  delay(1000); 

  // 3. 후진 (다시 들어가기)
  Serial.println("Actuator: BACKWARD START");
  bitClear(registerState, MOTOR_ACT1_BIT); // Q1 = 0
  bitSet(registerState, MOTOR_ACT2_BIT);   // Q2 = 1 (이게 들어가는 신호입니다)
  updateShiftRegister();
  delay(3000); // 완전히 들어갈 때까지 대기

  // 4. 최종 정지 (모터 보호)
  bitClear(registerState, MOTOR_ACT1_BIT);
  bitClear(registerState, MOTOR_ACT2_BIT);
  updateShiftRegister();
  Serial.println("Actuator: ALL STOP");
  delay(1000);
}

